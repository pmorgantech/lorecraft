{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/audit-log-pre.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/audit-log-post.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-lint.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scripting-docs-check.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/graph-refresh.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git fetch *)",
      "Bash(source /home/petem/src/Gamedev/lorecraft/.venv/bin/activate)",
      "Bash(source .venv/bin/activate)",
      "mcp__graphify__get_neighbors",
      "Bash(python -m pytest *)",
      "Bash(pytest *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(.venv/bin/pytest *)",
      "Bash(python -m venv *)",
      "Bash(python3 -m venv *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(echo *)",
      "Bash(ruff *)",
      "Bash(python -m ruff *)",
      "Bash(.venv/bin/ruff *)",
      "Bash(basedpyright *)",
      "Bash(python -m basedpyright *)",
      "Bash(.venv/bin/basedpyright *)",
      "Bash(make *)",
      "Bash(bash scripts/bootstrap-worktree.sh)",
      "Bash(cargo fmt *)",
      "Bash(cargo clippy *)",
      "Bash(cargo test *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)"
    ]
  }
}
